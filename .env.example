# ==========================================
# DigitalOcean Snapshot & Restore Tool
# Environment Variables Configuration
# ==========================================

# ------------------------------------------
# Authentication
# ------------------------------------------
# Your DigitalOcean Personal Access Token. 
# Alternatively, use 1Password CLI to provide this securely.
DO_API_TOKEN="dop_v1_your_token_here"

# ------------------------------------------
# UI Preferences
# ------------------------------------------
# Set to 1 to disable all ANSI color escape codes in output.
NO_COLOR=1 

# Set to 1 to bypass all confirmation prompts.
# (Equivalent to passing --force or -y as arguments)
NON_INTERACTIVE=1

# ------------------------------------------
# Snapshot Script Variables
# ------------------------------------------
# Provide these to skip interactive selection during do-snapshot.sh
DROPLET_ID="123456789"
SNAPSHOT_NAME="my-custom-snapshot-name"

# ------------------------------------------
# Restore Script Variables
# ------------------------------------------
# Provide these to skip interactive selection during do-restore.sh
SNAPSHOT_ID="987654321"
SIZE_SLUG="s-2vcpu-4gb"
SSH_KEY_ID="1234567"
DROPLET_NAME="restored-droplet-name"
RESERVED_IP="203.0.113.1"
DROPLET_TAGS="web,production"
VPC_UUID="your-vpc-uuid"
USER_DATA_FILE="/path/to/cloud-init.yaml"

# ------------------------------------------
# Slack Integration (AWS Lambda)
# ------------------------------------------
# These are used in the AWS Lambda Environment Configuration
SLACK_SIGNING_SECRET="your_slack_app_signing_secret"
SSM_INSTANCE_ID="i-0abcdef1234567890" # Instance ID of the backend runner machine
