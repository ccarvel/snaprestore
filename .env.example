# ==========================================
# DigitalOcean Snapshot & Restore Tool
# Environment Variables Configuration
# ==========================================
#
# HOW TO USE THIS FILE
# --------------------
# Option A (Recommended — 1Password):
#   Copy this file to .env.op and replace values with op:// references.
#   Then run: op run --env-file=".env.op" -- ./do-snapshot.sh
#   The `op` CLI resolves secrets at runtime — nothing plaintext on disk.
#
# Option B (Plain .env):
#   Copy this file to .env, fill in real values, and source it:
#   set -a && source .env && set +a
#   WARNING: Never commit .env to version control.
#
# Both .env and .env.op are listed in .gitignore.

# ------------------------------------------
# Authentication
# ------------------------------------------
# Your DigitalOcean Personal Access Token.
#
# 1Password (recommended):
#   Store:  op item create --category login --title "DigitalOcean PAT" --vault Private credential="dop_v1_..."
#   Read:   op read "op://Private/DigitalOcean PAT/credential"
#   .env.op value: op://Private/DigitalOcean PAT/credential
#
DO_API_TOKEN="dop_v1_your_token_here"

# ------------------------------------------
# UI Preferences
# ------------------------------------------
# Set to 1 to disable all ANSI color escape codes in output.
NO_COLOR=1

# Set to 1 to bypass all confirmation prompts.
# (Equivalent to passing --force or -y as arguments)
NON_INTERACTIVE=1

# ------------------------------------------
# Snapshot Script Variables
# ------------------------------------------
# Provide these to skip interactive selection during do-snapshot.sh
DROPLET_ID="123456789"
SNAPSHOT_NAME="my-custom-snapshot-name"

# ------------------------------------------
# Restore Script Variables
# ------------------------------------------
# Provide these to skip interactive selection during do-restore.sh
SNAPSHOT_ID="987654321"
SIZE_SLUG="s-2vcpu-4gb"
SSH_KEY_ID="1234567"
DROPLET_NAME="restored-droplet-name"
RESERVED_IP="203.0.113.1"
DROPLET_TAGS="web,production"
VPC_UUID="your-vpc-uuid"
USER_DATA_FILE="/path/to/cloud-init.yaml"

# ------------------------------------------
# Slack Integration (AWS Lambda)
# ------------------------------------------
# These are used in the AWS Lambda Environment Configuration.
# See: slack-integration/README_slack_integration.md
#
# 1Password (recommended):
#   Store Slack secret:
#     op item create --category login --title "SnapRestore Slack App" --vault Private signing_secret="..."
#   Read:  op read "op://Private/SnapRestore Slack App/signing_secret"
#   .env.op value: op://Private/SnapRestore Slack App/signing_secret
#
#   Store runner instance ID:
#     op item create --category login --title "SnapRestore Runner" --vault Private instance_id="i-0abc..."
#   Read:  op read "op://Private/SnapRestore Runner/instance_id"
#   .env.op value: op://Private/SnapRestore Runner/instance_id
#
SLACK_SIGNING_SECRET="your_slack_app_signing_secret"
SSM_INSTANCE_ID="i-0abcdef1234567890" # Instance ID of the backend runner machine
