# ============================================================
# snaprestore — Environment Variable Reference
# ============================================================
# Copy this file to .env, then inject secrets via op run:
#
#   cp .env.example .env
#   op run --env-file=.env -- ./do-snapshot.sh
#   op run --env-file=.env -- ./do-restore.sh
#
# op run resolves op:// references at runtime and injects them
# as environment variables without writing tokens to disk.
#
# WARNING: Never commit .env with live tokens to version control.
#          .env and .env.* are listed in .gitignore; .env.example is not.
# ============================================================

# ── DigitalOcean API token ────────────────────────────────────
# Used by do-snapshot.sh and do-restore.sh when DOCTL_CONTEXT is not set.
# Scopes required: see README.md § API token scopes.
# Create a token at: https://cloud.digitalocean.com/account/api/tokens
#
#DIGITALOCEAN_ACCESS_TOKEN=op://<your-vault>/DigitalOcean API Token snaprestore-scripts/credential

# Legacy alias — only needed if DIGITALOCEAN_ACCESS_TOKEN is unset.
#DO_API_TOKEN=op://<your-vault>/DigitalOcean API Token snaprestore-scripts/credential

# ── doctl auth context ────────────────────────────────────────
# If set, both scripts pass --context to every doctl call.
# The context's stored token takes precedence over the env var above.
# Initialize once with: doctl auth init --context snaprestore
#
#DOCTL_CONTEXT=snaprestore

# ── 1Password service account (controller droplet / CI) ──────
# Required in non-interactive environments where `op` cannot
# prompt for authentication (the Slack bot controller droplet,
# CI runners, cloud-init scripts).
# Create at: 1password.com → Developer → Service Accounts
#
#OP_SERVICE_ACCOUNT_TOKEN=ops_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Slack bot ─────────────────────────────────────────────────
# These variables are needed when running the Slack bot without
# the slack-bot/.env.op file (e.g. direct export for local dev).
# For production use, prefer: op run --env-file=slack-bot/.env.op
# See also: slack-bot/.env.op.example
#
# Slack Bot User OAuth Token (xoxb-…)
# Source: api.slack.com/apps → OAuth & Permissions
#SLACK_BOT_TOKEN=op://<your-vault>/do-snap-bot/slack-bot-token

# Slack App-Level Token for Socket Mode (xapp-…)
# Source: api.slack.com/apps → Settings → Socket Mode
#SLACK_APP_TOKEN=op://<your-vault>/do-snap-bot/slack-app-token

# Slack Signing Secret
# Source: api.slack.com/apps → Basic Information → App Credentials
#SLACK_SIGNING_SECRET=op://<your-vault>/do-snap-bot/signing-secret

# DigitalOcean token scoped to the Slack bot's operations.
# Can share the same token as DIGITALOCEAN_ACCESS_TOKEN above,
# or use a narrower-scoped token dedicated to the bot.
#DIGITALOCEAN_ACCESS_TOKEN=op://<your-vault>/do-snap-bot/do-token

# Comma-separated Slack member IDs allowed to run slash commands.
# Find a user's ID in Slack: click their profile → ⋮ → Copy member ID.
# Leave empty to allow all workspace members (not recommended).
#SLACK_ALLOWED_USERS=op://<your-vault>/do-snap-bot/allowed-users
