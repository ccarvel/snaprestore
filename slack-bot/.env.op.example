# 1Password references for do-snap-bot secrets.
# Usage: op run --env-file=.env.op -- uv run python bot.py
#
# Store each value in 1Password at the path shown, then copy this file to
# .env.op (do NOT commit .env.op — it contains live op:// references).
#
# WARNING: Never write actual tokens or secrets to this file or .env.op.
# The `op run` command resolves references at runtime and injects them as
# environment variables without writing them to disk.

SLACK_BOT_TOKEN=op://Private/do-snap-bot/slack-bot-token
SLACK_APP_TOKEN=op://Private/do-snap-bot/slack-app-token
SLACK_SIGNING_SECRET=op://Private/do-snap-bot/signing-secret
DIGITALOCEAN_ACCESS_TOKEN=op://Private/do-snap-bot/do-token

# Comma-separated Slack user IDs (e.g. U01AB2CD3,U04XY5EF6).
# Leave empty to allow all workspace members (not recommended for production).
SLACK_ALLOWED_USERS=op://Private/do-snap-bot/allowed-users
