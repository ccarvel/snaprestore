# 1Password references for do-snap-bot secrets.
# Usage: op run --env-file=.env.op -- uv run python bot.py
#
# Store each value in 1Password at the path shown, then copy this file to
# .env.op (do NOT commit .env.op — it contains live op:// references).
#
# WARNING: Never write actual tokens or secrets to this file or .env.op.
# The `op run` command resolves references at runtime and injects them as
# environment variables without writing them to disk.

SLACK_BOT_TOKEN=op://<your-vault>/do-snap-bot/slack-bot-token
SLACK_APP_TOKEN=op://<your-vault>/do-snap-bot/slack-app-token
SLACK_SIGNING_SECRET=op://<your-vault>/do-snap-bot/signing-secret
DIGITALOCEAN_ACCESS_TOKEN=op://<your-vault>/do-snap-bot/do-token

# Comma-separated Slack user IDs (e.g. U01AB2CD3,U04XY5EF6).
# Leave empty to allow all workspace members (not recommended for production).
SLACK_ALLOWED_USERS=op://<your-vault>/do-snap-bot/allowed-users

# ── Scheduled snapshots (optional) ──────────────────────────────────────────
# Set SNAPSHOT_SCHEDULE_INTERVAL_HOURS to enable automatic snapshots on a
# recurring schedule. The bot will post results to SNAPSHOT_SCHEDULE_CHANNEL.
#
# SNAPSHOT_SCHEDULE_INTERVAL_HOURS — how often to auto-snapshot (e.g. 24 for daily)
# SNAPSHOT_SCHEDULE_CHANNEL        — Slack channel ID where results are posted (e.g. C01234ABCDE)
# SNAPSHOT_SCHEDULE_DROPLET        — droplet name or ID to snapshot; if omitted and only
#                                    one droplet exists, that droplet is used automatically.
#
# Leave all three unset (or commented out) to disable scheduled snapshots.
#SNAPSHOT_SCHEDULE_INTERVAL_HOURS=24
#SNAPSHOT_SCHEDULE_CHANNEL=C01234ABCDE
#SNAPSHOT_SCHEDULE_DROPLET=my-droplet

# ── Snapshot retention policy (optional) ────────────────────────────────────
# After each snapshot (manual or scheduled), the bot will prune old snapshots
# for the same droplet. Set one or both rules; if both are set, the more
# aggressive rule wins (a snapshot is pruned if it fails either rule).
#
# SNAPSHOT_RETENTION_DAYS  — delete snapshots older than N days
# SNAPSHOT_RETENTION_COUNT — keep only the N most recent snapshots per droplet
#
# Leave both unset (or commented out) to disable retention pruning.
#SNAPSHOT_RETENTION_DAYS=30
#SNAPSHOT_RETENTION_COUNT=5
